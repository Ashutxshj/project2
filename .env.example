# AI key for the ATS resume checker (app/api/ats-check). Copy this file to .env.local
# and set ONE of the two keys. If both are set, Gemini is used.

# Google Gemini key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
# Optional: override the Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Or an Anthropic key from https://console.anthropic.com
# ANTHROPIC_API_KEY=your-anthropic-key-here
